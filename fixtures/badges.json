                        "target": "profile.user"
                    },
                    {
                        "name": "filter",
                        "lookup": "count__gte",
                        "target": "1"
                    },
                    {
                        "name": "filter",
                        "lookup": "count__lt",
                        "target": "10"
                    },
                    {
                        "name": "exists",
                        "lookup": "",
                        "target": ""
                    }
                ]
            }
        }
    },
    {
        "model": "users.badge",
        "pk": 6,
        "fields": {
            "name": "One Year Service Badge",
            "picture": "https://example.com/one_year_service_badge.png",
            "description": "Awarded to users who have been with the platform for one year.",
            "logic": {
                "app": "users.User",
                "filters": [
                    {
                        "name": "filter",
                        "lookup": "date_joined__lt",
                        "target": "now() - timedelta(days=365)"
                    },
                    {
                        "name": "exists",
