                        "target": "False"
                    },
                    {
                        "name": "filter",
                        "lookup": "pronoun__isnull",
                        "target": "False"
                    },
                    {
                        "name": "filter",
                        "lookup": "about__isnull",
                        "target": "False"
                    },
                    {
                        "name": "filter",
                        "lookup": "wikidata_qid__isnull",
                        "target": "False"
                    },
                    {
                        "name": "exists",
                        "lookup": "",
                        "target": ""
                    }
                ]
            }
        }
    },
    {
        "model": "users.badge",
        "pk": 5,
        "fields": {
            "name": "First Message Badge",
            "picture": "https://example.com/first_message_badge.png",
            "description": "Awarded to users who have sent their first message.",
            "logic": {
                "app": "message.Message",
                "filters": [
                    {
                        "name": "filter",
