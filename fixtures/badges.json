[
    {
        "model": "users.badge",
        "pk": 1,
        "fields": {
            "name": "Manager Badge",
            "picture": "https://example.com/manager_badge.png",
            "description": "Awarded to users who are managers of an organization.",
            "logic": {
                "app": "orgs.Organization",
                "filters": [
                    {
                        "name": "filter",
                        "lookup": "managers",
                        "target": "profile.user"
                    },
                    {
                        "name": "exists",
                        "lookup": "",
                        "target": ""
                    }
                ]
            }
        }
    },
    {
        "model": "users.badge",
        "pk": 2,
        "fields": {
            "name": "Messages Sent Badge",
            "picture": "https://example.com/messages_sent_badge.png",
            "description": "Awarded to users who have sent at least 10 messages.",
            "logic": {
                "app": "message.Message",
                "filters": [
                    {
                        "name": "filter",
                        "lookup": "sender",
                        "target": "profile.user"
                    },
                    {
                        "name": "filter",
                        "lookup": "count__gte",
                        "target": "10"
                    }
                ]
            }
        }
    },
    {
        "model": "users.badge",
        "pk": 3,
        "fields": {
            "name": "Profile Updated Recently Badge",
            "picture": "https://example.com/profile_updated_badge.png",
            "description": "Awarded to users who updated their profile in the last 3 months.",
            "logic": {
                "app": "users.Profile",
                "filters": [
                    {
                        "name": "filter",
                        "lookup": "last_update__gte",
                        "target": "now() - timedelta(days=90)"
                    },
                    {
                        "name": "exists",
                        "lookup": "",
                        "target": ""
                    }
                ]
            }
        }
    },
    {
        "model": "users.badge",
        "pk": 4,
        "fields": {
            "name": "Complete Profile Badge",
            "picture": "https://example.com/complete_profile_badge.png",
            "description": "Awarded to users who have filled all required profile fields.",
            "logic": {
                "app": "users.Profile",
                "filters": [
                    {
                        "name": "filter",
